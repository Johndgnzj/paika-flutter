rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 預設拒絕所有
    match /{document=**} {
      allow read, write: if false;
    }

    // 連結碼（任何登入用戶皆可讀寫，10 分鐘後自動失效由 App 控制）
    match /linkCodes/{code} {
      allow read, delete: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['code', 'playerProfileId', 'fromAccountId', 'expiresAt'])
        && request.resource.data.size() <= 10;
    }

    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // 用戶 profile
      allow read: if isOwner();
      allow create: if isOwner()
        && request.resource.data.keys().hasAll(['displayName', 'createdAt'])
        && request.resource.data.size() <= 10;
      allow update: if isOwner()
        && request.resource.data.size() <= 10;
      allow delete: if false;

      // 設定
      match /settings/{doc} {
        allow read: if isOwner();
        allow write: if isOwner()
          && request.resource.data.size() <= 20;
      }

      // 玩家檔案
      match /playerProfiles/{profileId} {
        // 自己可讀；被連結的用戶也可讀（用於跨帳號 collectionGroup 查詢）
        allow read: if isOwner()
          || (request.auth != null && resource.data.linkedAccountId == request.auth.uid);
        allow create: if isOwner()
          && request.resource.data.keys().hasAll(['name', 'emoji'])
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 50
          && request.resource.data.size() <= 15;
        // 自己可完整更新；被連結用戶只能將 linkedAccountId 設為自己的 uid（連結操作）
        allow update: if (isOwner()
            && request.resource.data.keys().hasAll(['name', 'emoji'])
            && request.resource.data.name is string
            && request.resource.data.name.size() <= 50
            && request.resource.data.size() <= 15)
          || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedAccountId'])
            && request.resource.data.linkedAccountId == request.auth.uid);
        allow delete: if isOwner();
      }

      // 牌局
      match /games/{gameId} {
        // 自己可讀寫；有 linkedSources 紀錄的用戶可讀（跨帳號查詢場次）
        allow read: if isOwner()
          || (request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid)/linkedSources/$(userId)));
        allow create, update: if isOwner()
          && request.resource.data.keys().hasAll(['id', 'status', 'players'])
          && request.resource.data.size() <= 500;
        allow delete: if isOwner();
      }

      // 帳號頭像（任何登入用戶可讀，用於顯示連結玩家的頭像；只有擁有者可寫）
      match /accountAvatar/{doc} {
        allow read: if request.auth != null;
        allow write: if isOwner();
      }

      // 已存玩家
      match /savedPlayers/{doc} {
        allow read: if isOwner();
        allow write: if isOwner()
          && request.resource.data.size() <= 100;
      }

      // 連結來源（記錄我連結到哪些帳號，用於跨帳號讀取場次）
      // 結構：{ ownerUid: string, profileId: string }
      match /linkedSources/{ownerUid} {
        allow read: if isOwner();
        allow write: if isOwner()
          && request.resource.data.size() <= 10;
      }
    }
  }
}
